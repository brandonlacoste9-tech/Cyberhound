# 🔒 Empire Configuration - Copy to .env and fill in your credentials
# DO NOT COMMIT .env TO GIT - IT IS IN .gitignore

# Gmail SMTP Settings
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Gmail IMAP Settings (for watchdog)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_16_char_app_password_here
IMAP_SERVER=imap.gmail.com

# To get App Password:
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate: https://myaccount.google.com/apppasswords

# Google Vertex AI / Gemini
VERTEX_API_KEY=your_vertex_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
VERTEX_PROJECT_ID=your_gcp_project_id_here

# Apify API (for lead enrichment + web scraping)
APIFY_API_TOKEN=your_apify_api_token_here

# Closing Loop — Sequence Engine
CALENDLY_URL=https://calendly.com/northernventures/15min
STRIPE_AUDIT_LINK=https://buy.stripe.com/YOUR_AUDIT_PRODUCT_LINK
STRIPE_RETAINER_LINK=https://buy.stripe.com/YOUR_RETAINER_PRODUCT_LINK
