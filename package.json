{
  "name": "cyberhound",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo type-check",
    "smoke": "pnpm -C apps/web run test:smoke",
    "check:env": "pnpm -C apps/web run check:env",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run build",
    "preflight": "pnpm run verify && pnpm run check:env"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.4"
}
