# CyberHound — Colony OS
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# Validate: pnpm run check:env    (strict: pnpm run check:env -- --strict)

# ============================================================
# Database — Supabase (required for persistence)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# LLM — use at least one path (Queen, Scout, Builder, Telegram)
# ============================================================
# Primary cloud fallback (used when OpenClaw is not available):
DEEPSEEK_API_KEY=sk-...

# Optional OpenAI-compatible (legacy / alternate):
# OPENAI_API_KEY=sk-...

# Optional OpenClaw gateway (prod: set URL; dev tries localhost by default):
# OPENCLAW_BASE_URL=https://your-gateway/v1
# OPENCLAW_GATEWAY_TOKEN=openclaw
# OPENCLAW_MODEL=default

# ============================================================
# Site URL (Open Graph + Builder Bee landing_page_url in production)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Dev: silence Next.js cross-origin warning when using LAN IP (match host:port from `pnpm dev`)
# NEXT_ALLOWED_DEV_ORIGINS=http://192.168.2.28:3002

# ============================================================
# Scout Bee — auto-approve (optional)
# ============================================================
# Default if unset: 78
# SCOUT_AUTO_APPROVE_MIN_SCORE=78

# ============================================================
# Scout / Analyst — Firecrawl (optional)
# ============================================================
FIRECRAWL_API_KEY=fc-...

# ============================================================
# Builder / Treasurer — Stripe (optional)
# ============================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ============================================================
# HITL — Telegram (optional)
# ============================================================
TELEGRAM_BOT_TOKEN=123456:ABC-...
# Same chat used by notify.ts and webhook admin checks:
TELEGRAM_CHAT_ID=123456789

# ============================================================
# Closer / Scheduler — Resend (optional)
# ============================================================
RESEND_API_KEY=re_...

# ============================================================
# Enrich Bee — Apollo (optional)
# ============================================================
# APOLLO_API_KEY=...

# ============================================================
# Scheduler cron auth (optional)
# ============================================================
# SCHEDULER_SECRET=cyberhound-scheduler
