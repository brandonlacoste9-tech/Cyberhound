{
  "framework": "nextjs",
  "buildCommand": "cd apps/web && npx next build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/scheduler",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/hunt",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/analyst",
      "schedule": "30 */2 * * *"
    }
  ]
}
